rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- REGRAS DO PROJETO SENTINELA STP ---

    // 1. Roadmap Estratégico
    // Permite leitura e escrita apenas para usuários autenticados (Login Agente)
    match /artifacts/sentinela-stp/public/roadmap {
      allow read, write: if request.auth != null;
    }

    // 2. Notícias e Artigos (Admin News)
    // Público pode ler, mas apenas administradores logados podem criar/editar/excluir
    match /artifacts/sentinela-stp/public/data/artigos/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Evidências e Relatos (App Principal)
    // Qualquer pessoa (mesmo anônima) pode enviar evidências. 
    // A leitura das evidências brutas é restrita aos agentes logados.
    match /artifacts/sentinela-stp/public/data/evidencias/{evidenciaId} {
      allow create: if true; 
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /interactions/{interactionId} {
        allow read, create, update, delete: if request.auth != null && interactionId == request.auth.uid;
      }
    }

    // 3b. Telemetria de Motoristas (Trajetos completos)
    // Separado de evidências de passageiros. Motorista (anônimo autenticado) escreve apenas os próprios dados.
    // Leitura liberada para administradores logados (email/senha).
    match /artifacts/sentinela-stp/public/data/telemetria_viagens/{tripId} {
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if request.auth != null && (request.auth.token.email != null || resource.data.ownerUid == request.auth.uid);

      match /chunks/{chunkId} {
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/artifacts/sentinela-stp/public/data/telemetria_viagens/$(tripId)).data.ownerUid == request.auth.uid;
        allow read: if request.auth != null &&
          (request.auth.token.email != null || get(/databases/$(database)/documents/artifacts/sentinela-stp/public/data/telemetria_viagens/$(tripId)).data.ownerUid == request.auth.uid);
        allow update: if false;
        allow delete: if request.auth != null &&
          (request.auth.token.email != null || get(/databases/$(database)/documents/artifacts/sentinela-stp/public/data/telemetria_viagens/$(tripId)).data.ownerUid == request.auth.uid);
      }
    }

    match /artifacts/sentinela-stp/public/data/enquetes/{respId} {
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.clientAtMs is int &&
        request.resource.data.eixoRegiao is string &&
        request.resource.data.eixoRegiao.size() <= 20 &&
        request.resource.data.linha is string &&
        request.resource.data.linha.size() <= 120 &&
        request.resource.data.bairro is string &&
        request.resource.data.bairro.size() <= 80 &&
        request.resource.data.nome is string &&
        request.resource.data.nome.size() <= 80 &&
        request.resource.data.consent is bool &&
        request.resource.data.q1 is string && request.resource.data.q1.size() <= 1200 &&
        request.resource.data.q2 is string && request.resource.data.q2.size() <= 1200 &&
        request.resource.data.q3 is string && request.resource.data.q3.size() <= 1200 &&
        request.resource.data.q4 is string && request.resource.data.q4.size() <= 1200 &&
        request.resource.data.q5 is string && request.resource.data.q5.size() <= 1200 &&
        request.resource.data.q6 is string && request.resource.data.q6.size() <= 1200 &&
        request.resource.data.q7 is string && request.resource.data.q7.size() <= 1200 &&
        request.resource.data.q8 is string && request.resource.data.q8.size() <= 1200 &&
        request.resource.data.q9 is string && request.resource.data.q9.size() <= 1200 &&
        request.resource.data.q10 is string && request.resource.data.q10.size() <= 1200 &&
        request.resource.data.q11 is string && request.resource.data.q11.size() <= 1200 &&
        request.resource.data.q12 is string && request.resource.data.q12.size() <= 1200 &&
        request.resource.data.q13 is string && request.resource.data.q13.size() <= 1200;
      allow read: if request.auth != null && request.auth.token.email != null;
      allow update, delete: if false;
    }

    // 4. Configurações Globais (Se houver)
    match /artifacts/sentinela-stp/public/config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 5. Patronos (Para Testes)
    // Leitura pública para o Quadro de Honra e Feed.
    // Criação pública para permitir que o script de simulação funcione.
    match /artifacts/sentinela-stp/public/data/patrons/{patronId} {
      allow read: if true;
      allow create: if true; // ATENÇÃO: Apenas para testes. Em produção, restrinja a escrita.
      allow update, delete: if false;
    }

    // Regra de segurança padrão: bloqueia tudo o que não foi definido acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
